{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "breizhstops",
  "compatibility_date": "2026-07-01",
  "pages_build_output_dir": ".",

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "breizhstops-db",
      "database_id": "e060ea26-eb7e-4c98-95ec-9d783dbb2770"
    }
  ],

  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "breizhstops-photos"
    }
  ]
,
  "vars": {
    "NOTION_VEHICLES_DATABASE_ID": "2e66bbfa7ec1804f963bc019a4d6de92",
    "NOTION_PARKING_DATABASE_ID": "35e6bbfa7ec180a18deff12d69f95ebc",
    "NOTION_TODO_DATABASE_ID": "3846bbfa7ec180928dc0d29a9b7aa8c6",
    "NOTION_WORKSHOP_DATABASE_ID": "2e66bbfa7ec1804f963bc019a4d6de92",
    "NOTION_SICKLEAVE_DATABASE_ID": "34d6bbfa7ec180e89ac2da151f11e266",
    "NOTION_WORKS_DATABASE_ID": "34c6bbfa7ec18064bfcad668439fe31d"
  }
}
